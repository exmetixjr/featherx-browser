modules = ["java-graalvm22.3"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Gradle Tasks"

[[workflows.workflow]]
name = "Gradle Tasks"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "./gradlew tasks --no-daemon"

[workflows.workflow.metadata]
outputType = "console"
