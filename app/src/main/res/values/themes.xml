<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.FeatherX" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent</item>
        <item name="colorPrimaryVariant">@color/accent_dim</item>
        <item name="colorOnPrimary">@color/text_primary</item>
        <item name="colorSurface">@color/bg_surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/bg_surface</item>
        <item name="bottomSheetStyle">@style/FeatherXBottomSheet</item>
    </style>

    <style name="FeatherXBottomSheet" parent="Widget.MaterialComponents.BottomSheet">
        <item name="backgroundTint">@color/bg_surface</item>
        <item name="android:elevation">8dp</item>
    </style>

    <style name="ToolBtn">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">18sp</item>
        <item name="android:background">?attr/selectableItemBackground</item>
        <item name="android:gravity">center</item>
    </style>
</resources>
