<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <LinearLayout
        android:id="@+id/main_browser_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Tab strip (top, like desktop browsers) -->
        <LinearLayout
            android:id="@+id/tab_strip_row"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:orientation="horizontal"
            android:background="@color/bg_dark"
            android:gravity="center_vertical"
            android:paddingStart="6dp"
            android:paddingEnd="6dp">

            <HorizontalScrollView
                android:id="@+id/tab_strip_scroll"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:scrollbars="none"
                android:fillViewport="false">

                <LinearLayout
                    android:id="@+id/tab_strip"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingTop="4dp" />
            </HorizontalScrollView>

            <ImageButton
                android:id="@+id/btn_new_tab_strip"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="4dp"
                android:src="@drawable/ic_plus"
                android:scaleType="centerInside"
                android:background="@drawable/bg_toolbar_btn"
                android:contentDescription="@string/btn_new_tab" />
        </LinearLayout>

        <!-- Toolbar (back / forward / reload / home / URL bar / tabs / overflow) -->
        <LinearLayout
            android:id="@+id/toolbar_row"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:background="@color/bg_surface"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:elevation="2dp"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_toolbar_btn"
                android:src="@drawable/ic_back"
                android:scaleType="centerInside"
                android:contentDescription="@string/btn_back" />

            <ImageButton
                android:id="@+id/btn_forward"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_toolbar_btn"
                android:src="@drawable/ic_forward"
                android:scaleType="centerInside"
                android:contentDescription="@string/btn_forward" />

            <ImageButton
                android:id="@+id/btn_reload"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_toolbar_btn"
                android:src="@drawable/ic_reload"
                android:scaleType="centerInside"
                android:contentDescription="@string/btn_reload" />

            <ImageButton
                android:id="@+id/btn_home"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_toolbar_btn"
                android:src="@drawable/ic_home"
                android:scaleType="centerInside"
                android:contentDescription="@string/btn_home" />

            <!-- URL bar with leading lock + trailing bookmark -->
            <LinearLayout
                android:id="@+id/url_bar_container"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_url_bar"
                android:paddingStart="10dp"
                android:paddingEnd="6dp">

                <ImageView
                    android:id="@+id/url_lock"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_globe_small"
                    android:contentDescription="@string/btn_site_info" />

                <EditText
                    android:id="@+id/url_bar"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="4dp"
                    android:hint="@string/url_hint"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:textSize="13sp"
                    android:background="@android:color/transparent"
                    android:singleLine="true"
                    android:imeOptions="actionGo"
                    android:inputType="textUri"
                    android:selectAllOnFocus="true" />

                <ImageButton
                    android:id="@+id/btn_bookmark"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:padding="4dp"
                    android:scaleType="centerInside"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_bookmark"
                    android:contentDescription="@string/btn_bookmark" />
            </LinearLayout>

            <FrameLayout
                android:layout_width="40dp"
                android:layout_height="40dp">

                <ImageButton
                    android:id="@+id/btn_tabs"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_toolbar_btn"
                    android:src="@drawable/ic_tabs"
                    android:scaleType="centerInside"
                    android:contentDescription="@string/btn_tabs" />

                <TextView
                    android:id="@+id/tab_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="4dp"
                    android:layout_marginEnd="2dp"
                    android:background="@drawable/bg_tab_badge"
                    android:textColor="@color/text_primary"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:minWidth="16dp"
                    android:gravity="center"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp"
                    android:text="@string/tab_count" />
            </FrameLayout>

            <ImageButton
                android:id="@+id/btn_overflow"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_toolbar_btn"
                android:src="@drawable/ic_overflow"
                android:scaleType="centerInside"
                android:contentDescription="@string/btn_overflow" />

        </LinearLayout>

        <!-- Progress bar -->
        <ProgressBar
            android:id="@+id/progress_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:progressTint="@color/accent"
            android:visibility="gone" />

        <!-- Find-in-page bar -->
        <LinearLayout
            android:id="@+id/find_bar"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:background="@color/bg_surface_2"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:gravity="center_vertical"
            android:visibility="gone">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_find"
                android:contentDescription="@string/menu_find" />

            <EditText
                android:id="@+id/find_input"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:hint="@string/find_hint"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:textSize="14sp"
                android:background="@android:color/transparent"
                android:singleLine="true"
                android:imeOptions="actionSearch" />

            <TextView
                android:id="@+id/find_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:paddingEnd="6dp"
                android:paddingStart="6dp"
                android:text="" />

            <ImageButton
                android:id="@+id/find_prev"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_arrow_up"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/find_prev" />

            <ImageButton
                android:id="@+id/find_next"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_arrow_down"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/find_next" />

            <ImageButton
                android:id="@+id/find_close"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_close"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/find_close" />

        </LinearLayout>

        <!-- WebView wrapped in pull-to-refresh -->
        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/swipe_refresh"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <WebView
                android:id="@+id/webview"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    </LinearLayout>

    <!-- Full-screen overlay container for tabs / bookmarks / history / settings -->
    <FrameLayout
        android:id="@+id/overlay_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/bg_dark"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone" />

</FrameLayout>
