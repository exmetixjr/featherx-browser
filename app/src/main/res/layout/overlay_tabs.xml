<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="@color/bg_surface"
        android:gravity="center_vertical"
        android:paddingStart="6dp"
        android:paddingEnd="6dp">

        <ImageButton
            android:id="@+id/tabs_close"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_close"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Close" />

        <TextView
            android:id="@+id/tabs_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Tabs"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginStart="6dp" />

        <ImageButton
            android:id="@+id/tabs_close_all"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_trash"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Close all tabs" />

        <ImageButton
            android:id="@+id/tabs_add"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_plus"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="New tab" />
    </LinearLayout>

    <!-- Category chips (Normal / Incognito / Search) -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingTop="10dp"
        android:paddingBottom="6dp">

        <LinearLayout
            android:id="@+id/tabs_chip_row"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp" />
    </HorizontalScrollView>

    <!-- Tab grid -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbarStyle="outsideOverlay">

        <LinearLayout
            android:id="@+id/tabs_grid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp" />
    </ScrollView>

    <!-- Bottom new tab + incognito toggle -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="@color/bg_surface"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <ImageButton
            android:id="@+id/tabs_incognito_toggle"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_incognito"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Toggle incognito" />

        <TextView
            android:id="@+id/tabs_incognito_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="New tabs: Normal"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:layout_marginStart="6dp" />

        <Button
            android:id="@+id/tabs_done"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="Done"
            android:textColor="@color/text_primary"
            android:textAllCaps="false"
            android:background="@drawable/bg_button_accent"
            android:paddingStart="20dp"
            android:paddingEnd="20dp" />

    </LinearLayout>

</LinearLayout>
